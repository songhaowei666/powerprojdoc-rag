# Rename this file to .env and put your own keys in it
# You can ignore api keys for jina and gemini, if you don't plan to use them

OPENAI_API_KEY=
OPENAI_API_BASE=

GEMINI_API_KEY=

# Jina Reranker v2 from https://jina.ai/reranker/
JINA_API_KEY=

# MinerU API Key from https://mineru.net/
MINERU_API_KEY=

# ChromaDB 向量库持久化目录（为空时使用默认值 data/projdoc_data/databases/vector_dbs）
CHROMA_PERSIST_DIR=

# BM25 索引输出目录（为空时使用默认值 data/projdoc_data/databases/bm25_index）
BM25_OUTPUT_DIR=

# 报告 JSON 输入目录（为空时使用默认值 data/projdoc_data/databases/chunked_reports）
REPORTS_INPUT_DIR=
